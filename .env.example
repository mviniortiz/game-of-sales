# =============================================================================
# Game Sales - Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# FRONTEND (Vite - prefixed with VITE_)
# -----------------------------------------------------------------------------

VITE_SUPABASE_PROJECT_ID="your_supabase_project_id"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_publishable_key"

# Mercado Pago (use TEST keys for dev, PROD keys for production)
VITE_MERCADOPAGO_PUBLIC_KEY="your_mercadopago_public_key"

# Sentry (optional - error tracking)
VITE_SENTRY_DSN=""

# Google Analytics 4 (optional - funnel tracking)
VITE_GA_MEASUREMENT_ID=""

# Google Ads Conversion Tracking (optional)
# CONVERSION_ID: formato AW-XXXXXXXXXX (copiar do Google Ads)
# CONVERSION_LABEL: conversão de compra/registro (checkout)
# DEMO_CONVERSION_LABEL: conversão de lead (form de demo) — SEM AW-.../ prefix, só a label
VITE_GADS_CONVERSION_ID=""
VITE_GADS_CONVERSION_LABEL=""
VITE_GADS_DEMO_CONVERSION_LABEL=""

# -----------------------------------------------------------------------------
# BACKEND (Supabase Edge Functions - set via `supabase secrets set`)
# -----------------------------------------------------------------------------
# These are NOT used by the frontend. Configure them in your Supabase project:
#   supabase secrets set KEY=value
#
# Core (auto-provided by Supabase):
#   SUPABASE_URL
#   SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#
# Google OAuth (google-oauth-init, google-oauth-callback, google-calendar-*):
#   GOOGLE_CLIENT_ID="your_google_client_id"
#   GOOGLE_CLIENT_SECRET="your_google_client_secret"
#   GOOGLE_CALENDAR_WEBHOOK_SECRET="your_webhook_secret"
#
# Twilio Voice (deal-call-*, twilio-*):
#   TWILIO_ACCOUNT_SID="your_account_sid"
#   TWILIO_AUTH_TOKEN="your_auth_token"
#   TWILIO_PHONE_NUMBER="+5511999999999"
#   TWILIO_API_KEY="your_api_key"
#   TWILIO_API_SECRET="your_api_secret"
#   TWILIO_TWIML_APP_SID="your_twiml_app_sid"
#   TWILIO_WEBHOOK_SECRET="your_webhook_secret"
#
# OpenAI (deal-call-transcribe, deal-call-generate-insights, whatsapp-copilot):
#   OPENAI_API_KEY="sk-..."
#
# Resend Email (admin-create-seller):
#   RESEND_API_KEY="re_..."
#   RESEND_FROM_EMAIL="Game Sales <noreply@gameofsales.com.br>"
#   APP_URL="https://gameofsales.com.br"
#
# Evolution WhatsApp API (evolution-whatsapp):
#   EVOLUTION_API_URL="https://your-evolution-instance.com"
#   EVOLUTION_API_KEY="your_evolution_api_key"
#
# Mercado Pago Backend (mercadopago-webhook, mercadopago-create-subscription):
#   MERCADOPAGO_ACCESS_TOKEN="your_access_token"
#   MERCADOPAGO_WEBHOOK_SECRET="your_webhook_secret"
#
# Frontend URL for OAuth redirects (google-oauth-callback):
#   FRONTEND_URL="https://gameofsales.com.br"

# ElevenLabs (voiceover do vídeo Remotion SalesVideoV2):
#   ELEVENLABS_API_KEY="sk_..."
# Opcional — sobrescreve voice default (Brian/nPczCjzI2devNBz1zQrb):
#   ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"
