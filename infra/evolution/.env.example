# ── Evolution API — variáveis de ambiente ────────────────────────────────────
# Copie pra `.env` (cp .env.example .env) e troque os valores marcados.

# 1) Chave da API. Gere uma forte:  openssl rand -hex 32
#    ESTA chave tem que ser a MESMA que vou pôr no Supabase (EVOLUTION_API_KEY).
AUTHENTICATION_API_KEY=TROQUE_POR_UMA_CHAVE_FORTE_64_HEX

# 2) URL pública do servidor. Pra começar: http://SEU_IP_PUBLICO:8080
#    (depois dá pra trocar por https://seu-dominio com o Caddy — ver MIGRACAO.md)
SERVER_URL=http://SEU_IP_PUBLICO:8080

# 3) Senha do Postgres. Use a MESMA aqui e na DATABASE_CONNECTION_URI abaixo.
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE

# ── Banco (Postgres) ──
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:TROQUE_POR_UMA_SENHA_FORTE@postgres:5432/evolution?schema=public
DATABASE_CONNECTION_CLIENT_NAME=evolution
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true

# ── Cache (Redis) ── deixa o Baileys leve e estável (chave da zumbi).
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/0
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=true
CACHE_LOCAL_ENABLED=false

# ── Diversos ──
DEL_INSTANCE=false
LOG_LEVEL=ERROR
LOG_BAILEYS=error
